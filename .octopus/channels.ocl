channel "Release" {
    Name = "Release"
    Description = "Production release channel"
    IsDefault = true
    LifecycleId = "Standard Promotion"
}

channel "Review" {
    Name = "Review"
    Description = "Review environment channel"
    IsDefault = false
    LifecycleId = "Standard Promotion"
}

channel "Hotfix" {
    Name = "Hotfix"
    Description = "Emergency hotfix channel"
    IsDefault = false
    LifecycleId = "Standard Promotion"
}





